    "Data/Library 受沙盒保护，迁移会致应用崩溃。请迁移其子目录。" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Data/Library is sandbox-protected. Migrating it will crash the app. Please migrate its subdirectories instead."
          }
        },
        "br" : {
