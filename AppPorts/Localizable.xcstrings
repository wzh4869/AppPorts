    "该目录位于沙盒容器内，macOS 会校验容器完整性。迁移会导致应用启动崩溃。" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "hada aldaleel fi dakhil hafizat alrimal. yatahadat macOS min salamat alhafizat. sayajalt alttahil alttatbiq eind albash."
          }
        },
        "br" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⠠⠞⠓⠊⠎ ⠙⠊⠗⠑⠉⠞⠕⠗⠽ ⠊⠎ ⠊⠝⠎⠊⠙⠑ ⠁ ⠎⠁⠝⠙⠃⠕⠭ ⠉⠕⠝⠞⠁⠊⠝⠑⠗⠲ ⠍⠁⠉⠠⠕⠠⠎ ⠧⠁⠇⠊⠙⠁⠞⠑⠎ ⠉⠕⠝⠞⠁⠊⠝⠑⠗ ⠊⠝⠞⠑⠛⠗⠊⠞⠽⠲ ⠠⠍⠊⠛⠗⠁⠞⠊⠕⠝ ⠺⠊⠇⠇ ⠉⠁⠥⠎⠑ ⠞⠓⠑ ⠁⠏⠏ ⠞⠕ ⠉⠗⠁⠎⠓ ⠕⠝ ⠇⠁⠥⠝⠉⠓⠲"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieses Verzeichnis befindet sich in einem Sandbox-Container. macOS ueberprueft die Container-Integritaet. Eine Migration fuehrte zum Absturz der App beim Start."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This directory is inside a sandbox container. macOS validates container integrity. Migration will cause the app to crash on launch."
          }
        },
        "eo" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chi tiu direktoro troviighas ene de sabloksa ujo. macOS validas la integritecon de la ujo. Migrado kauxus kracon de la aplikacio dum lancho."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Este directorio esta dentro de un contenedor sandbox. macOS verifica la integridad del contenedor. La migracion haria que la app se cierre inesperadamente al iniciar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce repertoire se trouve dans un conteneur sandbox. macOS verifie l'integrite du conteneur. La migration provoquerait un plantage de l'application au demarrage."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "yah drectory sandbox container ke andar hai. macOS container ki ekta ki jaanch karta hai. maigreshan se app shuru hone par kraash ho jaayega."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Direktori ini berada di dalam wadah sandbox. macOS memvalidasi integritas wadah. Migrasi akan menyebabkan aplikasi mogok saat diluncurkan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
