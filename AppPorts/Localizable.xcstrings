          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Do cấu trúc ứng dụng iOS, biểu tượng Finder sẽ hiển thị mũi tên sau khi di chuyển (hành vi hệ thống macOS)."
          }
