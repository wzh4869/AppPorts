    "在原位置自动创建符号链接，系统和 Launchpad 依然能正常识别应用。" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إنشاء روابط رمزية تلقائيًا. يتعرف النظام و Launchpad على التطبيقات بشكل طبيعي."
          }
        },
        "br" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⠠⠁⠥⠞⠕⠍⠁⠞⠊⠉⠁⠇⠇⠽ ⠉⠗⠑⠁⠞⠑ ⠎⠽⠍⠇⠊⠝⠅⠎ ⠊⠝ ⠏⠇⠁⠉⠑⠲ ⠠⠎⠽⠎⠞⠑⠍ ⠁⠝⠙ ⠠⠇⠁⠥⠝⠉⠓⠏⠁⠙ ⠗⠑⠉⠕⠛⠝⠊⠵⠑ ⠁⠏⠏⠎ ⠁⠎ ⠝⠕⠗⠍⠁⠇⠲"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erstellt automatisch symbolische Verknüpfungen. System und Launchpad erkennen Apps normal."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Automatically create symlinks in place. System and Launchpad recognize apps as normal."
          }
        },
        "eo" : {
          "stringUnit" : {
            "state" : "translated",
