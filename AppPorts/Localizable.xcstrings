    "感谢你使用本工具，外置硬盘拯救世界！": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "شكرا لاستخدامك. محركات الأقراص الخارجية تنقذ العالم!"
          }
        },
        "br": {
          "stringUnit": {
            "state": "translated",
            "value": "⠠⠞⠓⠁⠝⠅⠎ ⠋⠕⠗ ⠥⠎⠊⠝⠛⠲ ⠠⠑⠭⠞⠑⠗⠝⠁⠇ ⠙⠗⠊⠧⠑⠎ ⠎⠁⠧⠑ ⠞⠓⠑ ⠺⠕⠗⠇⠙⠖"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Danke für die Nutzung. Externe Laufwerke retten die Welt!"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Thanks for using. External drives save the world!"
          }
        },
        "eo": {
          "stringUnit": {
            "state": "translated",
            "value": "Dankon pro uzado. Eksteraj diskoj savas la mondon!"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Gracias por usar! ¡Los discos externos salvan el mundo!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Merci d'utiliser. Les disques externes sauvent le monde !"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "उपयोग के लिए धन्यवाद। बाहरी ड्राइव दुनिया बचाते हैं!"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Terima kasih telah menggunakan. Drive eksternal menyelamatkan dunia!"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Grazie per l'uso. Le unità esterne salvano il mondo!"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ご利用ありがとうございます。外部ドライブが世界を救う！"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이용해 주셔서 감사합니다. 외부 드라이브가 세상을 구합니다!"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bedankt voor het gebruik. Externe schijven redden de wereld!"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dzięki za używanie. Dyski zewnętrzne ratują świat!"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Obrigado por usar. Unidades externas salvam o mundo!"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Спасибо за использование. Внешние диски спасают мир!"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ขอบคุณที่ใช้บริการ ไดรฟ์ภายนอกกู้โลก!"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kullandığınız için teşekkürler. Harici sürücüler dünyayı kurtarır!"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Cảm ơn bạn đã sử dụng. Ổ đĩa ngoài cứu thế giới!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "感谢你使用本工具，外置硬盘拯救世界！"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "感謝你使用本工具，外接硬碟拯救世界！"
          }
        }
      }
    },
