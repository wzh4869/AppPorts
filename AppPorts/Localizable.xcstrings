        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'app a besoin d'un accès lecture/écriture à /Applications. Activez dans les Réglages."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ऐप को /Applications तक पहुंच की आवश्यकता है। कृपया सेटिंग्स में सक्षम करें।"
          }
        },
        "id" : {
          "stringUnit" : {
