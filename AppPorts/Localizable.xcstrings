        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Créez automatiquement des liens symboliques. Le système et le Launchpad reconnaissent les applications normalement."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "स्वचालित रूप से सिम्लिंक बनाएं। सिस्टम और लॉन्चपैड ऐप्स को सामान्य रूप से पहचानते हैं।"
          }
        },
        "id" : {
          "stringUnit" : {
