        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aufgrund der iOS-App-Struktur zeigt das Finder-Symbol nach der Migration einen Pfeil (macOS-Systemverhalten)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
