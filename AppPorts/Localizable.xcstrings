    "由于 iOS 应用结构限制，迁移后 Finder 图标会显示箭头（macOS 系统行为）" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بسبب هيكل تطبيق iOS، سيظهر رمز Finder سهمًا بعد الترحيل (سلوك نظام macOS)."
          }
        },
        "br" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "⠠⠙⠥⠑ ⠞⠕ ⠊⠠⠕⠠⠎ ⠁⠏⠏ ⠎⠞⠗⠥⠉⠞⠥⠗⠑⠂ ⠠⠋⠊⠝⠙⠑⠗ ⠊⠉⠕⠝ ⠺⠊⠇⠇ ⠎⠓⠕⠺ ⠁⠝ ⠁⠗⠗⠕⠺ ⠁⠋⠞⠑⠗ ⠍⠊⠛⠗⠁⠞⠊⠕⠝ ⠐⠣⠍⠁⠉⠠⠕⠠⠎ ⠎⠽⠎⠞⠑⠍ ⠃⠑⠓⠁⠧⠊⠕⠗⠐⠜⠲"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aufgrund der iOS-App-Struktur zeigt das Finder-Symbol nach der Migration einen Pfeil (macOS-Systemverhalten)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Due to iOS app structure, Finder icon will show an arrow after migration (macOS system behavior)."
          }
        },
        "eo" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pro strukturo de iOS-aplikaĵo, Finder-ikono montros sagon post migrado (sisteme konduto de macOS)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Debido a la estructura de la app iOS, el icono del Finder mostrará una flecha (comportamiento del sistema macOS)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En raison de la structure de l'app iOS, l'icône du Finder affichera une flèche (comportement système macOS)."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS ऐप संरचना के कारण, माइग्रेशन के बाद फाइंडर आइकन एक तीर दिखाएगा (macOS सिस्टम व्यवहार)।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Karena struktur aplikasi iOS, ikon Finder akan menampilkan panah setelah migrasi (perilaku sistem macOS)."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A causa della struttura dell'app iOS, l'icona del Finder mostrerà una freccia (comportamento di sistema macOS)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOSアプリの構造上、移行後のFinderアイコンには矢印が表示されます（macOSの仕様）。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iOS 앱 구조로 인해 마이그레이션 후 Finder 아이콘에 화살표가 표시됩니다(macOS 시스템 동작)."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vanwege de structuur van iOS-apps toont het Finder-pictogram een pijl na migratie (macOS-systeemgedrag)."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ze względu na strukturę aplikacji iOS, ikona Findera pokaże strzałkę po migracji (zachowanie systemu macOS)."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Devido à estrutura do app iOS, o ícone do Finder mostrará uma seta (comportamento do sistema macOS)."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Из-за структуры приложения iOS значок Finder будет показывать стрелку (системное поведение macOS)."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "เนื่องจากโครงสร้างแอป iOS ไอคอน Finder จะแสดงลูกศรหลังจากย้าย (พฤติกรรมของระบบ macOS)"
          }
        },
        "tr" : {
          "stringUnit" : {
